generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id                 Int            @id @default(autoincrement())
  schoolName         String
  email              String?
  phone              String?
  address            String?
  logo               String?
  subscriptionStatus String?
  subscriptionExpiry DateTime?
  maxStudents        Int?
  studentCount       Int            @default(0)
  createdAt          DateTime       @default(now())
  schoolCode         String         @unique
  Admin              Admin[]
  attendance         Attendance[]
  courses            Course[]
  feeInvoices        FeeInvoice[]
  payments           FeePayment[]
  feeStructures      FeeStructure[]
  notices            Notice[]
  principals         Principal[]
  students           Student[]
  teachers           Teacher[]
  timetables         Timetable[]
  accountants        Accountant[]
}

model Course {
  id            Int            @id @default(autoincrement())
  schoolId      Int
  courseName    String
  section       String
  academicYear  String
  teacherId     Int?           @unique
  createdAt     DateTime       @default(now())
  attendance    Attendance[]
  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher       Teacher?       @relation(fields: [teacherId], references: [id])
  feeStructures FeeStructure[]
  notices       Notice[]
  students      Student[]
  timetables    Timetable[]

  @@unique([schoolId, courseName, section, academicYear])
  @@index([schoolId])
}

model Principal {
  id       Int    @id @default(autoincrement())
  schoolId Int
  name     String
  email    String  @unique
  password String
  phone    String?
  school   School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

model Teacher {
  id             Int          @id @default(autoincrement())
  schoolId       Int
  name           String
  email          String       @unique
  password       String
  phone          String?
  employeeId     String       @unique
  createdAt      DateTime     @default(now())
  attendance     Attendance[]
  assignedCourse Course?
  school         School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  timetables     Timetable[]

  @@index([schoolId])
}

model Student {
  id            Int          @id @default(autoincrement())
  schoolId      Int
  studentId     String       @unique
  password      String
  name          String
  fatherName    String?
  motherName    String?
  phone         String?
  address       String?
  courseId      Int?
  rollNumber    String?
  admissionDate DateTime?
  createdAt     DateTime     @default(now())
  attendance    Attendance[]
  feeInvoices   FeeInvoice[]
  payments      FeePayment[]
  course        Course?      @relation(fields: [courseId], references: [id])
  school        School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

model Attendance {
  id        Int              @id @default(autoincrement())
  schoolId  Int
  studentId Int
  teacherId Int?
  courseId  Int?
  date      DateTime
  status    AttendanceStatus
  course    Course?          @relation(fields: [courseId], references: [id])
  school    School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher   Teacher?         @relation(fields: [teacherId], references: [id])

  @@unique([studentId, date])
  @@index([schoolId])
}

model Timetable {
  id        Int     @id @default(autoincrement())
  schoolId  Int
  teacherId Int
  courseId  Int
  dayOfWeek String
  period    String
  subject   String
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([schoolId, teacherId, dayOfWeek, period])
  @@index([schoolId])
}

model FeeStructure {
  id       Int       @id @default(autoincrement())
  schoolId Int
  courseId Int?
  feeType  String
  amount   Int
  dueDate  DateTime?
  course   Course?   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

model FeeInvoice {
  id        Int          @id @default(autoincrement())
  schoolId  Int
  studentId Int
  feeType   String
  amount    Int
  dueDate   DateTime
  status    FeeStatus    @default(PENDING)
  school    School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments  FeePayment[]

  @@index([schoolId])
}

model FeePayment {
  id            Int        @id @default(autoincrement())
  schoolId      Int
  studentId     Int
  feeInvoiceId  Int
  amount        Int
  date          DateTime   @default(now())
  status        String
  paymentMethod String
  receiptNumber String?
  feeInvoice    FeeInvoice @relation(fields: [feeInvoiceId], references: [id], onDelete: Cascade)
  school        School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student       Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

model Notice {
  id            Int            @id @default(autoincrement())
  schoolId      Int
  title         String
  content       String
  date          DateTime       @default(now())
  audience      NoticeAudience
  courseId      Int?
  attachmentUrl String?
  status        String         @default("PUBLISHED")
  scheduledAt   DateTime?
  course        Course?        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

model Admin {
  id       Int     @id @default(autoincrement())
  schoolId Int
  name     String
  email    String  @unique
  password String
  phone    String?
  School   School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

enum FeeStatus {
  PAID
  PENDING
  OVERDUE
}

enum NoticeAudience {
  SCHOOL
  COURSE
  TEACHERS
  STUDENTS
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model Accountant {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  email     String   @unique
  password  String
  phone     String?
  createdAt DateTime @default(now())

  @@index([schoolId])
}
